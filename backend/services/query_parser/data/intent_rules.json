    {
      "intent": "Career Advice",
      "priority": 38,
      "patterns": [
        "(?:career|job|future)\\s+(?:options?|opportunities?|scope|prospects?)",
        "(?:what|what are|what is|tell me about|suggest|find)\\s+(?:careers?|options?|scope|paths?)",
        "what\\s+(?:can|should)\\s+(?:i|we)\\s+(?:do|become|pursue)",
        "\\b(after|post)\\s+(mca|bca|b\\.?tech|m\\.?tech|bsc|msc|bcom|mcom|bba|mba)"
      ]
    },
    {
      "intent": "Explain",
      "priority": 20,
      "keywords": ["what is", "explain", "tell me about", "what does", "how does"]
    },
    {
      "intent": "Decision",
      "priority": 19,
      "keywords": ["should i", "which one", "help me decide", "confused", "suggest"]
    },
    {
      "intent": "Roadmap",
      "priority": 18,
      "keywords": ["roadmap", "how to", "step by step", "process", "procedure"]
    },
    {
      "intent": "Opportunity Search",
      "priority": 1,
      "keywords": []
    }
  ],
  "exploratory_patterns": [
    "opportunities?\\s+in\\s+\\w+",
    "scholarships?\\s+in\\s+\\w+",
    "phd\\s+(?:opportunities?|positions?|programs?|in)\\s+\\w+",
    "masters?\\s+(?:in|at|programs?|opportunities?)",
    "funded\\s+(?:phd|masters|positions?|programs?)",
    "(?:study|work|research)\\s+(?:in|abroad|overseas)",
    "list\\s+(?:of\\s+)?(?:scholarships|universities|programs|courses)",
    "top\\s+(?:scholarships|universities|programs|courses)"
  ],
  "personalization_patterns": [
    "(?:best|ideal|perfect|right|suitable)\\s+(?:for|scholarship|opportunity)",
    "(?:for|to)\\s+me\\b",
    "(?:my|my profile|my background|my qualifications?)",
    "am\\s+i\\s+(?:eligible|qualified|fit)",
    "can\\s+i\\s+(?:get|apply|qualify|avail)",
    "recommend\\s+(?:me|for me)",
    "suggest\\s+(?:me|for me)"
  ]
}
